{
  "name": "@xshuliner/build-info",
  "version": "0.1.0",
  "description": "Generate build, deploy, Git and CI information for frontend applications.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "xshuliner",
  "homepage": "https://github.com/xshuliner/build-info#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xshuliner/build-info.git"
  },
  "bugs": {
    "url": "https://github.com/xshuliner/build-info/issues"
  },
  "keywords": [
    "build-info",
    "deploy",
    "git",
    "ci",
    "vite",
    "nextjs",
    "react",
    "taro"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.12.1",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "xshuliner-build-info": "./dist/cli.js",
    "xbi": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup && node scripts/ensure-use-client.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "generate": "node dist/cli.js generate"
  },
  "peerDependencies": {
    "next": ">=13",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.3",
    "@types/react": "^19.1.8",
    "eslint": "^9.29.0",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
